PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret
DB_PATH=./data/optima.db

# Default admin account created on first run if no admin exists yet
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Monthly payroll cron schedule (default: 03:00 on the 1st of every month, server time)
# Only fires reliably if the process stays running at that moment — on hosts
# that sleep the app when idle (e.g. Render free tier), also set CRON_SECRET
# below and use the GitHub Actions workflow in .github/workflows to trigger
# payroll externally instead.
PAYROLL_CRON=0 3 1 * *

# Shared secret for POST /api/payroll/cron-trigger — lets an external
# scheduler (not a logged-in admin) run payroll on hosts where the process
# can be asleep at the scheduled time. Leave unset to disable that endpoint.
CRON_SECRET=

# How often (minutes) an employee's browser sends a live location ping while clocked in
LOCATION_PING_MINUTES=2
