PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret
DB_PATH=./data/optima.db

# Default admin account created on first run if no admin exists yet
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Monthly payroll cron schedule (default: 03:00 on the 1st of every month, server time)
PAYROLL_CRON=0 3 1 * *

# How often (minutes) an employee's browser sends a live location ping while clocked in
LOCATION_PING_MINUTES=2
